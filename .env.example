# Copy to .env and fill in your local mimOE endpoint details.
# The endpoint must be OpenAI-compatible.

# Base URL of your local mimOE inference endpoint (OpenAI-compatible).
MIMOE_BASE_URL=http://<your-mimoe-host>:8083/mimik-ai/openai/v1

# API key configured on your mimOE endpoint.
MIMOE_API_KEY=your-api-key

# Model loaded in mimOE.
MODEL_NAME=smollm-360m

# Optional: default patient id used when triaging a single report via CLI.
# PATIENT_ID=demo-patient
